# Copy this file to ".env" and fill in your values (or set them as real env vars).
# NEVER commit the real .env — it has secret tokens.

# You choose this string; you type the SAME value into Meta's webhook setup.
VERIFY_TOKEN=my_verify_token

# From Meta > WhatsApp > API Setup. Temporary token lasts 24h; make a permanent
# System User token for production.
WHATSAPP_TOKEN=EAAG...your_long_token...

# From the same API Setup page (the "Phone number ID", NOT the phone number).
PHONE_NUMBER_ID=1234567890

# Optional — bump when Meta releases a newer Graph API version.
GRAPH_API_VERSION=v21.0
